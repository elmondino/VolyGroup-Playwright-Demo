# Base URL for the Voly Group website
BASE_URL=https://www.volygroup.com

# URL for the Voly login application
LOGIN_URL=https://secure.voly.co.uk

# Environment gate for form submission tests.
# Form submit tests will be SKIPPED unless this is set to "dev" or "staging".
# Never run with "prod" - it will pollute the live Voly CRM with test data.
# Allowed values: prod | dev | staging
TEST_ENV=prod
